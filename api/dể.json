[{"word":"dể ngươi","definitions":[{"dicts":["Việt Anh - Hồ Ngọc Đức"],"text":"@dể ngươi\n* verb\n- to disregard","type":"bilingual"},{"dicts":["VNEDICT"],"text":"to disregard","type":"bilingual"},{"dicts":["Babylon"],"text":"[dể ngươi]động từ to disregard","type":"bilingual"},{"dicts":["Từ điển Tiếng Việt - Hồ Ngọc Đức"],"text":"@dể ngươi\n- đg. (cũ, hoặc ph.). Coi thường, không nể, không sợ. Phải dè chừng, đừng có dể ngươi.","type":"mono"}]},{"word":"dể","definitions":[{"dicts":["Babylon"],"text":"[dể] despise, hold in contempt, disdain","type":"bilingual"}]},{"word":"dể làm gì","definitions":[{"dicts":["VNEDICT"],"text":"what for, do what?","type":"bilingual"}]},{"word":"dể ám thị","definitions":[{"dicts":["VNEDICT"],"text":"suggestible","type":"bilingual"}]}]
[{"word":"tiếm chức","definitions":[{"dicts":["Babylon"],"text":"động từ to occupy a position (illegally)","type":"bilingual"}]},{"word":"tiếm ngôn","definitions":[{"dicts":["Babylon"],"text":"danh từ lie, falsehood, untruth, deception","type":"bilingual"}]},{"word":"tiếm loạn","definitions":[{"dicts":["Babylon"],"text":"như tiếm nghịch","type":"bilingual"}]},{"word":"tiếm danh","definitions":[{"dicts":["Babylon"],"text":"động từ usurp a name use the pretext of another name","type":"bilingual"}]},{"word":"tiếm vị","definitions":[{"dicts":["VNEDICT"],"text":"to usurp the throne","type":"bilingual"},{"dicts":["Babylon"],"text":"động từ to usurp the throne","type":"bilingual"},{"dicts":["Từ điển Tiếng Việt - Hồ Ngọc Đức"],"text":"@tiếm vị\n- Chiếm ngôi vua một cách phi pháp.","type":"mono"}]},{"word":"tiếm đoạt","definitions":[{"dicts":["VNEDICT"],"text":"to usurp","type":"bilingual"},{"dicts":["Babylon"],"text":"[tiếm đoạt] to usurp","type":"bilingual"},{"dicts":["Từ điển Tiếng Việt - Hồ Ngọc Đức"],"text":"@tiếm đoạt\n- Cướp quyền của kẻ khác: Tiếm đoạt ngôi vua.","type":"mono"}]},{"word":"tiếm nghịch","definitions":[{"dicts":["Babylon"],"text":"động từ rebel, revolt","type":"bilingual"}]},{"word":"tiếm ngôi","definitions":[{"dicts":["VNEDICT"],"text":"usurp the throne","type":"bilingual"},{"dicts":["Babylon"],"text":"động từ usurp the throne","type":"bilingual"}]},{"word":"tiếm mưu","definitions":[{"dicts":["Babylon"],"text":"tính từ swindding, cheating, knavery, imposture, deceit","type":"bilingual"}]},{"word":"tiếm mạn","definitions":[{"dicts":["Babylon"],"text":"tính từ arrogant, haghty, supercilious, overbearing","type":"bilingual"}]},{"word":"tiếm quyền","definitions":[{"dicts":["VNEDICT"],"text":"usurp somebody’s power","type":"bilingual"},{"dicts":["Babylon"],"text":"động từ usurp somebody's power","type":"bilingual"},{"dicts":["Từ điển Tiếng Việt - Hồ Ngọc Đức"],"text":"@tiếm quyền\n- Cg. Tiếm. Giành mất quyền của vua: Chúa Trịnh tiếm quyền vua Lê.","type":"mono"}]},{"word":"tiếm","definitions":[{"dicts":["Việt Anh - Hồ Ngọc Đức"],"text":"@tiếm\n* verb\n- to usurp","type":"bilingual"},{"dicts":["VNEDICT"],"text":"to usurp","type":"bilingual"},{"dicts":["Babylon"],"text":"[tiếm]động từ to usurp","type":"bilingual"},{"dicts":["Từ điển Tiếng Việt - Hồ Ngọc Đức"],"text":"@tiếm\n- đg. Nh. Tiếm quyền.","type":"mono"}]}]
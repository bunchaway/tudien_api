[{"word":"xõng","definitions":[{"dicts":["Từ điển Tiếng Việt thông dụng"],"text":"[lối nói] cụt ngủn, không có những tiếng xưng hô cần thiết, gây ấn tượng thiếu lịch sự\nVí dụ:\n- hỏi xõng \n - buông xõng một câu","type":"mono"},{"dicts":["Babylon"],"text":"tính từ /trạng từ stiff, rigid impolite, rude, impoliterly, rudely","type":"bilingual"}]},{"word":"xõng lưng","definitions":[{"dicts":["VNEDICT"],"text":"idle, unoccupied","type":"bilingual"},{"dicts":["Babylon"],"text":"tính từ idle, unoccupied","type":"bilingual"}]},{"word":"xõng đuôi","definitions":[{"dicts":["Babylon"],"text":"danh từ turned-up-tail","type":"bilingual"}]},{"word":"xõa","definitions":[{"dicts":["Việt Anh - Hồ Ngọc Đức"],"text":"@xõa\n* verb\n- hang","type":"bilingual"},{"dicts":["VNEDICT"],"text":"hang","type":"bilingual"}]},{"word":"xõng xõng","definitions":[{"dicts":["Babylon"],"text":"trạng từ indolently","type":"bilingual"}]}]
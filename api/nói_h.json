[{"word":"nói hết hơi","definitions":[{"dicts":["Babylon"],"text":"[nói hết hơi] to talk out of breath","type":"bilingual"}]},{"word":"nói hão","definitions":[{"dicts":["Babylon"],"text":"[nói hão] idle talk nó chỉ nói hão he never keeps his promise","type":"bilingual"}]},{"word":"nói hoẹt","definitions":[{"dicts":["VNEDICT"],"text":"speak glibly","type":"bilingual"},{"dicts":["Babylon"],"text":"[nói hoẹt] speak glibly","type":"bilingual"}]},{"word":"nói hoài","definitions":[{"dicts":["VNEDICT"],"text":"to keep talking, talk incessantly","type":"bilingual"}]},{"word":"nói hỗn","definitions":[{"dicts":["Babylon"],"text":"[nói hỗn] make a cheeky remark (to) nói hỗn với mẹ make a cheeky remark to one's mother","type":"bilingual"}]},{"word":"nói hết","definitions":[{"dicts":["VNEDICT"],"text":"to say everything, finish speaking","type":"bilingual"},{"dicts":["Babylon"],"text":"[nói hết] xem nói xong \n Nó chẳng cho tôi nói hết \n He did not let me finish","type":"bilingual"}]},{"word":"nói hộ","definitions":[{"dicts":["Việt Anh - Hồ Ngọc Đức"],"text":"@nói hộ\n- như","type":"bilingual"},{"dicts":["Babylon"],"text":"[nói hộ] xem nói giùm","type":"bilingual"}]},{"word":"nói hươu nói vượn","definitions":[{"dicts":["VNEDICT"],"text":"to talk nonsense, spin a yarn","type":"bilingual"},{"dicts":["Babylon"],"text":"[nói hươu nói vượn] to talk nonsense/rot \n Đừng nói hươu nói vượn nữa! \n Stop talking rot!","type":"bilingual"}]},{"word":"nói hớ","definitions":[{"dicts":["Việt Anh - Hồ Ngọc Đức"],"text":"@nói hớ\n- Blunder out","type":"bilingual"},{"dicts":["VNEDICT"],"text":"blunder out","type":"bilingual"},{"dicts":["Babylon"],"text":"[nói hớ] \n Blunder out. speak thoughtlessly","type":"bilingual"}]},{"word":"nói hết sự thật","definitions":[{"dicts":["Babylon"],"text":"[nói hết sự thật] to tell the whole truth","type":"bilingual"}]},{"word":"nói hớt","definitions":[{"dicts":["Việt Anh - Hồ Ngọc Đức"],"text":"@nói hớt\n- Tell tales","type":"bilingual"},{"dicts":["VNEDICT"],"text":"tell tales","type":"bilingual"},{"dicts":["Babylon"],"text":"[nói hớt] \n Tell tales.","type":"bilingual"}]}]
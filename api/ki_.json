[{"word":"Ki Tô","definitions":[{"dicts":["VNEDICT"],"text":"Christ","type":"bilingual"}]},{"word":"ki ốt","definitions":[{"dicts":["Từ điển Tiếng Việt thông dụng"],"text":"quầy nhỏ bán báo, kẹo, thuốc lá, hoa, vv ở nơi công cộng\nVí dụ:\n- hai bên đường mọc lên rất nhiều ki ốt \n - xây ki ốt để cho thuê","type":"mono"},{"dicts":["VNEDICT"],"text":"kiosk","type":"bilingual"}]},{"word":"ki lô mét","definitions":[{"dicts":["VNEDICT"],"text":"kilometer","type":"bilingual"},{"dicts":["Babylon"],"text":"[ki lô mét] kilometre \n Có nhiều nơi gió thổi tới 120 ki lô mét / giờ \n There are gusts of wind reaching 120 km/h in places","type":"bilingual"}]},{"word":"ki cóp","definitions":[{"dicts":["Từ điển Tiếng Việt thông dụng"],"text":"gom góp từng tí một để dồn lại thành món lớn\nVí dụ:\n- nó ki cóp được một số vốn kha khá","type":"mono"}]},{"word":"ki lô mét khối","definitions":[{"dicts":["Babylon"],"text":"[ki lô mét khối] cubic kilometre","type":"bilingual"}]},{"word":"ki mô nô","definitions":[{"dicts":["VNEDICT"],"text":"kimono","type":"bilingual"},{"dicts":["Babylon"],"text":"[ki mô nô] kimono","type":"bilingual"}]},{"word":"ki lô","definitions":[{"dicts":["Từ điển Tiếng Việt thông dụng"],"text":"kilogram [nói tắt]","type":"mono"},{"dicts":["Babylon"],"text":"[ki lô] xem ki lô gam","type":"bilingual"}]},{"word":"ki lô ca lo","definitions":[{"dicts":["VNEDICT"],"text":"(kilo)calories (food)","type":"bilingual"}]},{"word":"ki bo","definitions":[{"dicts":["Từ điển Tiếng Việt thông dụng"],"text":"rất bủn xỉn, chỉ biết bo bo giữ của\nVí dụ:\n- đồ ki bo! \n - ông ta giàu nhưng ki bo lắm","type":"mono"}]},{"word":"ki lô vôn","definitions":[{"dicts":["VNEDICT"],"text":"kilovolt","type":"bilingual"}]},{"word":"ki lô oát","definitions":[{"dicts":["VNEDICT"],"text":"kilowatt","type":"bilingual"}]},{"word":"ki lô gam","definitions":[{"dicts":["VNEDICT"],"text":"kilogram","type":"bilingual"},{"dicts":["Babylon"],"text":"[ki lô gam] kilogram \n Nặng dưới / trên một ki lô gam \n To be under/over 1 kilo in weight","type":"bilingual"}]},{"word":"ki nin","definitions":[{"dicts":["VNEDICT"],"text":"quinine","type":"bilingual"}]},{"word":"Ki Ri Xi Tô","definitions":[{"dicts":["VNEDICT"],"text":"Christ","type":"bilingual"}]},{"word":"ki lô mét vuông","definitions":[{"dicts":["VNEDICT"],"text":"square kilometer","type":"bilingual"},{"dicts":["Babylon"],"text":"[ki lô mét vuông] square kilometer","type":"bilingual"}]},{"word":"Ki Tô Giáo","definitions":[{"dicts":["VNEDICT"],"text":"Christianity","type":"bilingual"}]}]